{
  "name": "stagehand-stephy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Automated StephyTracking (Tecnoship) sign-in with Stagehand (local Chrome + OpenRouter). Shares the 'Mama SAN Amazon' Supabase DB.",
  "scripts": {
    "smoke": "tsx src/smoke.ts",
    "stephy": "tsx src/stephy-login.ts",
    "stephy:preview": "cross-env STEPHY_PREVIEW=1 tsx src/stephy-login.ts",
    "stephy:auto": "cross-env STEPHY_AUTORUN=1 tsx src/stephy-login.ts",
    "inspect": "tsx src/inspect-dom.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3",
    "@openrouter/ai-sdk-provider": "^1",
    "dotenv": "^17",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^24",
    "cross-env": "^7.0.3",
    "tsx": "^4",
    "typescript": "^5"
  }
}
